# Copy this to .env on the server and fill in real values.
# Generate secrets:
#   POSTGRES_PASSWORD: openssl rand -hex 24
#   JWT_SECRET:        openssl rand -hex 32
#   ENCRYPTION_KEY:    openssl rand -base64 32

POSTGRES_PASSWORD=change_me

# Must be at least 32 characters
JWT_SECRET=change_me_at_least_32_chars_long_!!

# 32-byte value base64-encoded
ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Google Maps (used by mobile app map screen)
GOOGLE_MAPS_API_KEY=

# Email / weekly digest (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TLS=true
DIGEST_DAY=Monday
DIGEST_HOUR_UTC=6
